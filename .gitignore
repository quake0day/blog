# Machine-translated EN mirror — generated by scripts/translate-posts.mjs.
# The folder and .gitkeep stay tracked so Astro's content collection
# loads even without translations present; translated .md + hash
# manifest are cached across CI runs via actions/cache, not committed.
src/content/posts-en/*
!src/content/posts-en/.gitkeep
