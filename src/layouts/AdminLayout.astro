---
interface Props {
  title?: string;
  requireEasymde?: boolean;
}
const { title = "Admin", requireEasymde = false } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Admin</title>
    <link rel="icon" href="/favicon.ico" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    {requireEasymde && (
      <>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.css" />
        <script is:inline src="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.js"></script>
      </>
    )}
    <style is:global>
      :root {
        --ink:          #111827;
        --ink-soft:     #4b5563;
        --ink-faded:    #9ca3af;
        --bg:           #f7f8fa;
        --bg-panel:     #ffffff;
        --rule:         #e5e7eb;
        --accent:       #3a9ad9;
        --accent-hover: #2080bb;
        --accent-soft:  #dbeaf7;
      }
      html, body { background: var(--bg); color: var(--ink); }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont,
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
          sans-serif;
        font-size: 14px;
      }
      .admin-nav-link {
        padding: 0.35rem 0.8rem;
        border-radius: 0.3rem;
        color: var(--ink-soft);
        font-size: 0.875rem;
        transition: all 0.15s;
        cursor: pointer;
      }
      .admin-nav-link:hover { background: var(--rule); color: var(--ink); }
      .admin-nav-link.active { background: var(--ink); color: white; }
      .admin-nav-link.active:hover { background: var(--ink); color: white; }
      .btn {
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.15s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
      }
      .btn-primary { background: var(--accent); color: white; }
      .btn-primary:hover:not(:disabled) { background: var(--accent-hover); }
      .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
      .btn-dark { background: var(--ink); color: white; }
      .btn-dark:hover:not(:disabled) { background: #000; }
      .btn-dark:disabled { opacity: 0.5; cursor: not-allowed; }
      .btn-secondary {
        border: 1px solid var(--rule);
        color: var(--ink-soft);
        background: white;
      }
      .btn-secondary:hover { background: #f3f4f6; color: var(--ink); }
      .btn-danger {
        color: #dc2626;
        border: 1px solid #fecaca;
        background: white;
      }
      .btn-danger:hover { background: #fef2f2; }
      .input {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--rule);
        border-radius: 0.375rem;
        background: white;
        font-size: 0.875rem;
        color: var(--ink);
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(58,154,217,0.18);
      }
      .label {
        display: block;
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--ink-faded);
        margin-bottom: 0.3rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .card {
        background: var(--bg-panel);
        border: 1px solid var(--rule);
        border-radius: 0.5rem;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.2em;
        padding: 2px 8px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent-hover);
        font-size: 12px;
        font-weight: 500;
      }
      .spinner {
        width: 14px; height: 14px;
        border: 2px solid var(--rule);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        display: inline-block;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* EasyMDE tweaks to fit the admin style */
      .EasyMDEContainer {
        font-size: 14px;
      }
      .EasyMDEContainer .CodeMirror {
        border-radius: 0.375rem;
        border-color: var(--rule);
        min-height: 480px;
        font-family:
          "JetBrains Mono", ui-monospace, "PingFang SC", monospace;
      }
      .EasyMDEContainer .editor-toolbar {
        border-color: var(--rule);
        background: var(--bg-panel);
      }
      .EasyMDEContainer .editor-preview, .EasyMDEContainer .editor-preview-side {
        background: var(--bg-panel);
        font-family:
          -apple-system, "PingFang SC", sans-serif;
      }
    </style>
  </head>
  <body class="min-h-screen">
    <nav class="bg-white sticky top-0 z-40" style="border-bottom: 1px solid var(--rule);">
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/admin/posts" class="text-base font-bold tracking-tight" style="color: var(--ink);">
          PSYcHiC <span style="color: var(--ink-faded);">· Admin</span>
        </a>
        <div class="flex items-center gap-1 text-sm">
          <a href="/admin/comments" class="admin-nav-link" data-nav="/admin/comments">留言</a>
          <a href="/admin/posts" class="admin-nav-link" data-nav="/admin/posts">文章</a>
          <a href="/" class="admin-nav-link">← 返回站点</a>
          <button id="admin-logout" class="admin-nav-link" style="color: #dc2626;">登出</button>
        </div>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-8">
      <slot />
    </main>

    <script is:inline>
      // Highlight active nav link based on current path
      (function () {
        var path = window.location.pathname;
        document.querySelectorAll("[data-nav]").forEach(function (el) {
          if (path.indexOf(el.getAttribute("data-nav")) === 0) {
            el.classList.add("active");
          }
        });
        var logout = document.getElementById("admin-logout");
        if (logout) {
          logout.addEventListener("click", function () {
            localStorage.removeItem("quake0day-admin-pw");
            window.location.reload();
          });
        }
      })();
    </script>
  </body>
</html>
