---
interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
}
const {
  title,
  description = "Si Chen's personal blog — thoughts, diary, tech, research. Since 2004.",
  ogType = "website",
} = Astro.props;
const siteTitle = "PSYcHiC";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
---
<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Si Chen" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url.href} />
    <title>{fullTitle}</title>
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            fontFamily: {
              sans: [
                "Inter",
                "-apple-system",
                "BlinkMacSystemFont",
                "PingFang SC",
                "Hiragino Sans GB",
                "Microsoft YaHei",
                "sans-serif",
              ],
              serif: ['"Noto Serif SC"', "Georgia", "serif"],
              mono: ['"JetBrains Mono"', "ui-monospace", "monospace"],
            },
            typography: ({ theme }) => ({
              DEFAULT: {
                css: {
                  "code::before": { content: '""' },
                  "code::after": { content: '""' },
                },
              },
            }),
          },
        },
      };
    </script>

    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap");
      body { font-family: "Inter", -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif; }
      .prose-body {
        font-family: "Noto Serif SC", "PingFang SC", Georgia, serif;
        font-size: 1.0625rem;
        line-height: 1.85;
      }
      .prose-body p { margin: 1.2em 0; }
      .prose-body h1 { font-size: 1.75rem; font-weight: 700; margin: 2em 0 0.7em; }
      .prose-body h2 { font-size: 1.45rem; font-weight: 700; margin: 1.8em 0 0.6em; }
      .prose-body h3 { font-size: 1.2rem; font-weight: 600; margin: 1.6em 0 0.5em; }
      .prose-body a { color: #2563eb; text-decoration: underline; text-underline-offset: 3px; }
      .prose-body a:hover { color: #1d4ed8; }
      .dark .prose-body a { color: #60a5fa; }
      .dark .prose-body a:hover { color: #93c5fd; }
      .prose-body img { max-width: 100%; height: auto; border-radius: 0.5rem; margin: 1em auto; display: block; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
      .prose-body blockquote {
        border-left: 3px solid #cbd5e1;
        padding-left: 1em;
        margin: 1.2em 0;
        color: #64748b;
        font-style: italic;
      }
      .dark .prose-body blockquote { border-color: #475569; color: #94a3b8; }
      .prose-body ul, .prose-body ol { padding-left: 1.5em; margin: 1em 0; }
      .prose-body li { margin: 0.35em 0; }
      .prose-body code {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.92em;
        padding: 0.1em 0.35em;
        background: #f1f5f9;
        border-radius: 0.25em;
      }
      .dark .prose-body code { background: #1e293b; }
      .prose-body pre {
        padding: 1em;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin: 1.2em 0;
        font-size: 0.9em;
      }
      .prose-body pre code { background: transparent; padding: 0; }
      .prose-body hr { border: 0; border-top: 1px solid #e5e7eb; margin: 2em 0; }
      .dark .prose-body hr { border-color: #374151; }
      .prose-body table { border-collapse: collapse; margin: 1.2em 0; }
      .prose-body th, .prose-body td { border: 1px solid #e5e7eb; padding: 0.5em 0.8em; }
      .dark .prose-body th, .dark .prose-body td { border-color: #374151; }
      [id] { scroll-margin-top: 80px; }
    </style>
  </head>

  <body class="bg-stone-50 dark:bg-gray-950 text-gray-800 dark:text-gray-200 antialiased transition-colors duration-300">
    <nav class="sticky top-0 z-50 bg-stone-50/85 dark:bg-gray-950/85 backdrop-blur-md border-b border-stone-200 dark:border-gray-800">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight text-gray-900 dark:text-white">PSYcHiC</a>
        <div class="flex items-center gap-1 sm:gap-3 text-sm">
          <a href="/" class="px-2.5 py-1.5 rounded hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors">Home</a>
          <a href="/archive" class="px-2.5 py-1.5 rounded hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors">Archive</a>
          <a href="/tags" class="px-2.5 py-1.5 rounded hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors">Tags</a>
          <a href="/about" class="px-2.5 py-1.5 rounded hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors">About</a>
          <a href="/rss.xml" title="RSS" class="px-2.5 py-1.5 rounded hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors">RSS</a>
          <button id="theme-toggle" class="ml-1 p-2 rounded-full hover:bg-stone-200 dark:hover:bg-gray-800 transition-colors" aria-label="Toggle dark mode">
            <svg class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/></svg>
            <svg class="w-4 h-4 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <slot />
    </main>

    <footer class="border-t border-stone-200 dark:border-gray-800 mt-16 py-8">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center text-xs text-gray-500 dark:text-gray-500">
        &copy; 2004-{new Date().getFullYear()} Si Chen.
        Built with <a href="https://astro.build" class="underline hover:text-gray-700 dark:hover:text-gray-300">Astro</a>,
        deployed on Cloudflare Pages.
        <a href="/rss.xml" class="underline hover:text-gray-700 dark:hover:text-gray-300 ml-1">RSS</a>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var html = document.documentElement;
        if (
          localStorage.getItem("theme") === "dark" ||
          (!localStorage.getItem("theme") && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          html.classList.add("dark");
        }
        var btn = document.getElementById("theme-toggle");
        if (btn) {
          btn.addEventListener("click", function () {
            html.classList.toggle("dark");
            localStorage.setItem(
              "theme",
              html.classList.contains("dark") ? "dark" : "light",
            );
          });
        }
      })();
    </script>

    <!-- Google Analytics (legacy UA) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=UA-8217718-4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'UA-8217718-4');
    </script>
  </body>
</html>
