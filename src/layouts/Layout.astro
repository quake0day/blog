---
interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
}
const {
  title,
  description = "Si Chen's personal blog — thoughts, diary, tech, research. Since 2004.",
  ogType = "website",
} = Astro.props;
const siteTitle = "PSYcHiC";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
---
<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Si Chen" />
    <meta name="theme-color" content="#e1f1fa" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url.href} />
    <title>{fullTitle}</title>
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = { darkMode: "class" };
    </script>

    <!--
      Font stack follows 蔡振原's guide:
        primary  = Montserrat + PingFang SC
        titles   = Noto Serif SC (for serif display contrast)
        mono     = JetBrains Mono
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Kami-style typography stack:
        sans     = Inter + PingFang SC (UI, body)
        serif    = Newsreader + Noto Serif SC (titles, editorial)
        mono     = JetBrains Mono
      Serif weight locked at 500 per Kami's single-weight rule.
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Noto+Serif+SC:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* ==========================================================
         Kami-style design tokens — warm parchment canvas + user's
         sky-blue kept as the single accent (kami uses ink blue
         #1B365D; we keep this blog's identity color).

         Principles borrowed from tw93/kami:
           · Parchment base, never pure white
           · Single accent, < 5% surface area
           · All neutrals warm (yellow-brown undertone)
           · Serif weight locked at 500
           · Line-height scale: 1.1-1.3 titles / 1.4-1.45 dense /
             1.5-1.55 reading body. Never 1.6+
           · No italic anywhere
           · Tag backgrounds in solid hex (rgba double-rect bug
             doesn't apply to web but keeps the tone consistent)
         ========================================================== */
      :root {
        /* canvas — warm parchment */
        --bg:          #f5f4ed;   /* parchment page bg */
        --bg-panel:    #faf9f5;   /* ivory lifted surface */
        --bg-soft:     #efede3;   /* between parchment and ivory */
        --bg-sand:     #e8e6dc;   /* warm sand, interactive surface */

        /* hairlines */
        --rule:        #e0ddd2;   /* visible border (warm) */
        --rule-soft:   #e8e5da;   /* subtler border */

        /* warm-neutral text ramp (yellow-brown undertone) */
        --ink:         #141413;   /* near-black, warm olive under-tone */
        --ink-soft:    #3d3d3a;   /* secondary */
        --ink-mid:     #4d4c48;   /* charcoal, dense body */
        --ink-faded:   #87867f;   /* stone, meta */

        /* the one accent — kept from prior design */
        --accent:      #3a9ad9;
        --accent-hover:#2080bb;
        --accent-deep: #1769a3;
        --accent-pale: #E4ECF5;   /* Kami-style solid tint for tags */

        /* hero canvas tones — parchment + barely-there sky hint */
        --hero-top:    #eef3f7;
        --hero-mid:    #f1efe4;

        /* legacy aliases still referenced in Comments/others */
        --bg-sky:      #dbecf5;
        --bg-sky-top:  #c2dcec;
        --bg-sky-soft: #edf3f8;
      }
      .dark {
        --bg:          #141413;   /* Kami deep-dark, not pure black */
        --bg-panel:    #1e1d1a;   /* warm dark surface */
        --bg-soft:     #262521;
        --bg-sand:     #30302e;   /* dark-surface */

        --rule:        #30302e;
        --rule-soft:   #262521;

        --ink:         #f1eee4;
        --ink-soft:    #c8c3b6;
        --ink-mid:     #a5a093;
        --ink-faded:   #87867f;

        --accent:      #62b8e6;
        --accent-hover:#8fd0ee;
        --accent-deep: #3a9ad9;
        --accent-pale: #1e3a55;

        --hero-top:    #1d2731;
        --hero-mid:    #1a1915;

        --bg-sky:      #1a2a3a;
        --bg-sky-top:  #203648;
        --bg-sky-soft: #1a231c;
      }

      html, body { background: var(--bg); color: var(--ink); }

      /* ==========================================================
         Typography — Inter sans + Newsreader/Noto Serif SC serif
         ========================================================== */
      body {
        font-family:
          "Inter",
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
          -apple-system, BlinkMacSystemFont, sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.55;                 /* Kami reading body */
        letter-spacing: 0;
        font-feature-settings: "kern" 1, "palt" 1, "tnum" 1, "ss01" 1, "cv11" 1;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-spacing-trim: auto;
      }

      /* Kami rule: never italic */
      em, i, cite, address, dfn, var, blockquote { font-style: normal; }

      .font-serif-sc {
        font-family:
          "Newsreader",
          "Noto Serif SC", "Source Han Serif SC",
          "Songti SC", "STSong",
          Georgia, serif;
        font-weight: 500;                  /* Kami: serif weight locked */
        font-optical-sizing: auto;
      }
      .font-mono {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-feature-settings: "tnum" 1, "zero" 1;
      }

      /* ==========================================================
         Section label (small caps eyebrow)
         ========================================================== */
      .eyebrow {
        font-family: "Inter", sans-serif;
        font-size: 11.5px;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent-deep);
      }
      .dark .eyebrow { color: var(--accent); }

      /* Decorative hairline rule — Kami prefers 1px whisper */
      .rule-accent {
        display: inline-block;
        width: 2.25rem;
        height: 1px;
        background: var(--accent);
      }

      /* ==========================================================
         Links
         ========================================================== */
      a { color: inherit; }
      .link-accent {
        color: var(--accent-deep);
        text-decoration: none;
        transition: color 0.15s;
      }
      .dark .link-accent { color: var(--accent); }
      .link-accent:hover { color: var(--accent-hover); }

      /* ==========================================================
         Prose body — Kami typography
         Reading body line-height capped at 1.55; titles tight 1.2-1.3.
         Headings use serif @ weight 500 (Kami single-weight rule).
         ========================================================== */
      .prose-body {
        font-size: 16px;
        line-height: 1.55;                 /* Kami reading body */
        color: var(--ink);
        letter-spacing: 0.002em;
        text-align: justify;
        text-align-last: left;
        text-justify: inter-character;
        hanging-punctuation: first allow-end last;
        word-wrap: break-word;
      }
      @media (min-width: 640px) {
        .prose-body { font-size: 17px; line-height: 1.55; }
      }
      .prose-body p { margin: 1.2em 0; }
      .prose-body p:first-child { margin-top: 0; }
      .prose-body p:last-child { margin-bottom: 0; }

      .prose-body h1, .prose-body h2, .prose-body h3, .prose-body h4 {
        font-family: "Newsreader", "Noto Serif SC", Georgia, serif;
        font-weight: 500;                  /* Kami locked weight */
        color: var(--ink);
        line-height: 1.25;
        text-align: left;
        letter-spacing: 0;
      }
      .prose-body h1 { font-size: 28px; margin: 2.4em 0 0.85em; }
      .prose-body h2 { font-size: 23px; margin: 2.1em 0 0.8em; }
      .prose-body h3 { font-size: 19px; margin: 1.8em 0 0.65em; line-height: 1.3; }
      .prose-body h4 { font-size: 17px; margin: 1.6em 0 0.55em; line-height: 1.3; font-weight: 600; }

      .prose-body a {
        color: var(--accent-deep);
        text-decoration: underline;
        text-decoration-thickness: 0.5px;
        text-underline-offset: 3px;
        text-decoration-color: var(--accent-pale);
        transition: color 0.15s, text-decoration-color 0.15s;
      }
      .dark .prose-body a { color: var(--accent); }
      .prose-body a:hover {
        color: var(--accent-hover);
        text-decoration-color: currentColor;
      }
      .prose-body strong { color: var(--ink); font-weight: 600; }
      /* Kami: no italic. Keep semantic <em> but render upright, emphasized by color only. */
      .prose-body em { font-style: normal; color: var(--ink-soft); }

      .prose-body img {
        max-width: 100%;
        height: auto;
        margin: 1.6em auto;
        display: block;
        border-radius: 3px;
        /* ring shadow only, no hard drop */
        box-shadow: 0 0 0 1px var(--rule);
      }
      .dark .prose-body img { box-shadow: 0 0 0 1px var(--rule); }

      .prose-body blockquote {
        border-left: 2px solid var(--accent);
        padding: 0.15em 0 0.15em 1.1em;
        margin: 1.4em 0 1.4em 0.3em;
        color: var(--ink-soft);
        font-style: normal;               /* Kami: no italic */
        text-align: left;
      }
      .prose-body blockquote p { margin: 0.45em 0; }
      .prose-body blockquote p:first-child { margin-top: 0; }
      .prose-body blockquote p:last-child { margin-bottom: 0; }

      .prose-body ul, .prose-body ol {
        padding-left: 1.35em;
        margin: 1em 0;
        text-align: left;
        line-height: 1.55;
      }
      .prose-body li { margin: 0.2em 0; }
      .prose-body ul li::marker { color: var(--accent); }

      .prose-body code {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.86em;
        padding: 0.1em 0.42em;
        background: var(--bg-panel);
        border: 1px solid var(--rule-soft);
        border-radius: 3px;
        color: var(--accent-deep);
      }
      .dark .prose-body code {
        color: var(--accent);
        background: var(--bg-soft);
        border-color: var(--rule);
      }
      .prose-body pre {
        padding: 1em 1.2em;
        border-radius: 4px;
        overflow-x: auto;
        margin: 1.5em 0;
        font-size: 13.5px;
        line-height: 1.55;
        background: var(--bg-panel);
        border: 1px solid var(--rule);
        text-align: left;
        color: var(--ink);
      }
      .prose-body pre code {
        background: transparent;
        padding: 0;
        color: inherit;
        border: none;
      }
      .dark .prose-body pre {
        background: #18171a;
        border-color: #30302e;
      }
      .dark .prose-body pre code { color: #d8d4c9; }

      .prose-body hr {
        border: 0;
        text-align: center;
        margin: 2.6em 0;
      }
      .prose-body hr::before {
        content: "· · ·";
        color: var(--ink-faded);
        letter-spacing: 0.6em;
        font-size: 1.1em;
      }

      .prose-body table {
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 14.5px;
      }
      .prose-body th, .prose-body td {
        border: 1px solid var(--rule);
        padding: 0.5em 0.8em;
        text-align: left;
      }
      .prose-body th { background: var(--bg-panel); font-weight: 600; }

      /* ==========================================================
         Home-only tokens — parchment hero with quiet sky whisper
         ========================================================== */
      .hero-panel {
        position: relative;
        overflow: hidden;
        background: linear-gradient(
          180deg,
          var(--hero-top) 0%,
          var(--hero-mid) 60%,
          var(--bg) 100%
        );
      }
      .hero-panel > * { position: relative; z-index: 1; }

      /* Softly drifting atmosphere — now warm tones instead of heavy sky. */
      .hero-cloud {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        filter: blur(70px);
        will-change: transform;
      }
      .hero-cloud-1 {
        width: 340px; height: 340px;
        top: -100px; left: -80px;
        background: radial-gradient(circle, var(--accent-pale) 0%, transparent 70%);
        opacity: 0.35;
        animation: drift-1 30s ease-in-out infinite;
      }
      .hero-cloud-2 {
        width: 400px; height: 280px;
        top: 50px; right: -120px;
        background: radial-gradient(ellipse, var(--bg-sand) 0%, transparent 70%);
        opacity: 0.45;
        animation: drift-2 36s ease-in-out infinite;
      }
      .hero-cloud-3 {
        width: 200px; height: 200px;
        bottom: -60px; left: 45%;
        background: radial-gradient(circle, var(--bg-panel) 0%, transparent 70%);
        opacity: 0.4;
        animation: drift-3 26s ease-in-out infinite;
      }
      @keyframes drift-1 {
        0%, 100% { transform: translate(0, 0); }
        50%      { transform: translate(45px, 30px); }
      }
      @keyframes drift-2 {
        0%, 100% { transform: translate(0, 0); }
        50%      { transform: translate(-55px, 40px); }
      }
      @keyframes drift-3 {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
        50%      { transform: translate(20px, -25px) scale(1.1); opacity: 0.5; }
      }

      .hero-title {
        font-family: "Newsreader", "Noto Serif SC", Georgia, serif;
        font-weight: 500;                   /* Kami: serif locked at 500 */
        letter-spacing: -0.005em;
        line-height: 1.05;
      }
      .hero-title span {
        display: inline-block;
        opacity: 0;
        transform: translateY(0.4em);
        animation: letterReveal 0.75s cubic-bezier(0.2, 0.85, 0.2, 1) forwards;
      }
      @keyframes letterReveal {
        to { opacity: 1; transform: translateY(0); }
      }

      .post-reveal {
        opacity: 0;
        transform: translateY(16px);
        transition:
          opacity   0.75s cubic-bezier(0.2, 0.8, 0.2, 1),
          transform 0.75s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .post-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-cloud { animation: none; }
        .hero-title span { opacity: 1; transform: none; animation: none; }
        .post-reveal { opacity: 1; transform: none; transition: none; }
      }

      .home-post-title {
        font-family: "Newsreader", "Noto Serif SC", Georgia, serif;
        font-weight: 500;                   /* Kami */
        line-height: 1.25;
        letter-spacing: 0;
        color: var(--ink);
      }
      .home-post-title a:hover { color: var(--accent-hover); }
      .home-post-date {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 11.5px;
        font-weight: 500;
        letter-spacing: 0.08em;
        color: var(--accent-deep);
      }
      .dark .home-post-date { color: var(--accent); }
      .home-post-tag {
        font-size: 11.5px;
        letter-spacing: 0.04em;
        font-weight: 500;
        color: var(--ink-faded);
      }

      .home-divider {
        height: 1px;
        background: linear-gradient(
          to right,
          transparent,
          var(--rule) 15%,
          var(--rule) 85%,
          transparent
        );
      }

      /* ==========================================================
         Comments & inputs — warm parchment surfaces with ring focus
         ========================================================== */
      .comment-card {
        background: var(--bg-panel);
        border: 1px solid var(--rule);
      }
      .dark .comment-card { background: var(--bg-soft); }

      .paper-input {
        background: var(--bg-panel);
        border: 1px solid var(--rule);
        color: var(--ink);
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .paper-input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-pale);   /* ring, Kami-style */
      }
      .dark .paper-input { background: var(--bg-panel); }

      .paper-btn {
        background: var(--accent);
        color: #fff;
        transition: background 0.15s, box-shadow 0.15s;
        letter-spacing: 0.08em;
        box-shadow: 0 0 0 1px var(--accent-deep);   /* Kami ring, not drop */
      }
      .paper-btn:hover { background: var(--accent-hover); }

      /* Date chip — Kami-style solid-hex tag, small radius */
      .chip-sky {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        padding: 3px 9px;
        border-radius: 3px;                  /* Kami 2-4pt radius */
        background: var(--accent-pale);
        color: var(--accent-deep);
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.06em;
      }
      .dark .chip-sky {
        background: var(--accent-pale);
        color: var(--accent);
      }

      /* Scroll offset */
      [id] { scroll-margin-top: 80px; }

      /* Selection */
      ::selection { background: var(--accent-pale); color: var(--ink); }
    </style>
  </head>

  <body class="antialiased">
    <nav class="sticky top-0 z-40 backdrop-blur-md" style="background: color-mix(in srgb, var(--bg) 85%, transparent); border-bottom: 1px solid var(--rule);">
      <div class="max-w-3xl mx-auto px-5 sm:px-8 py-3.5 flex items-center justify-between">
        <a href="/" class="text-[1.4rem] tracking-tight font-serif-sc" style="color: var(--ink);">PSYcHiC</a>
        <div class="flex items-center gap-0.5 sm:gap-1 text-sm" style="color: var(--ink-soft);">
          <a href="/" class="px-2.5 py-1.5 rounded hover:text-[color:var(--accent-deep)] transition-colors">Home</a>
          <a href="/archive" class="px-2.5 py-1.5 rounded hover:text-[color:var(--accent-deep)] transition-colors">Archive</a>
          <a href="/tags" class="px-2.5 py-1.5 rounded hover:text-[color:var(--accent-deep)] transition-colors">Tags</a>
          <a href="/about" class="px-2.5 py-1.5 rounded hover:text-[color:var(--accent-deep)] transition-colors">About</a>
          <a href="/rss.xml" title="RSS" class="px-2.5 py-1.5 rounded hover:text-[color:var(--accent-deep)] transition-colors">RSS</a>
          <button id="theme-toggle" class="ml-1 p-1.5 rounded-full hover:opacity-70 transition-opacity" aria-label="Toggle dark mode">
            <svg class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/></svg>
            <svg class="w-4 h-4 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="mt-28 py-12" style="border-top: 1px solid var(--rule);">
      <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center text-xs" style="color: var(--ink-faded);">
        <div class="mb-3 flex justify-center"><span class="rule-accent"></span></div>
        &copy; 2004&ndash;{new Date().getFullYear()} &nbsp; Si Chen
        &nbsp;&middot;&nbsp;
        Built with <a href="https://astro.build" class="link-accent">Astro</a>,
        hosted on Cloudflare Pages
        &nbsp;&middot;&nbsp;
        <a href="/rss.xml" class="link-accent">RSS</a>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var html = document.documentElement;
        if (localStorage.getItem("theme") === "dark") html.classList.add("dark");
        var btn = document.getElementById("theme-toggle");
        if (btn) {
          btn.addEventListener("click", function () {
            html.classList.toggle("dark");
            localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
          });
        }

        // Scroll-in reveal for posts on the home page (and any
        // element with .post-reveal anywhere else).
        if ("IntersectionObserver" in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          }, { threshold: 0.12, rootMargin: "0px 0px -60px 0px" });
          document.querySelectorAll(".post-reveal").forEach(function (el) {
            io.observe(el);
          });
        } else {
          // Old browser fallback — just show them.
          document.querySelectorAll(".post-reveal").forEach(function (el) {
            el.classList.add("is-visible");
          });
        }
      })();
    </script>

    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=UA-8217718-4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'UA-8217718-4');
    </script>
  </body>
</html>
