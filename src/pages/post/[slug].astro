---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Comments from "../../components/Comments.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const fmt = (d: Date) =>
  d.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" });
---
<Layout title={entry.data.title} description={entry.data.title} ogType="article">
  <article>
    <header class="mb-10 text-center">
      <div class="eyebrow mb-4" style="letter-spacing: 0.3em;">
        ◆&nbsp; 一篇日志 &nbsp;◆
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight mb-5" style="color: var(--ink);">
        {entry.data.title}
      </h1>
      <div class="flex items-center justify-center gap-3 text-sm flex-wrap" style="color: var(--ink-faded);">
        <time datetime={entry.data.date.toISOString()} class="font-mono text-xs">
          {fmt(entry.data.date)}
        </time>
        {entry.data.tags.length > 0 && (
          <span>·</span>
        )}
        <div class="flex flex-wrap gap-2 justify-center">
          {entry.data.tags.map((t: string) => (
            <a href={`/tagged/${encodeURIComponent(t)}`} class="text-xs link-accent" style="text-decoration: none;">
              #{t}
            </a>
          ))}
        </div>
      </div>
      <div class="mt-6" style="color: var(--ink-faded); letter-spacing: 0.5em;">· · ·</div>
    </header>

    <div class="prose-body">
      <Content />
    </div>
  </article>

  <div class="my-16 text-center" style="color: var(--ink-faded); letter-spacing: 0.5em;">· · ·</div>

  <Comments slug={entry.slug} />

  <div class="mt-16 pt-6 border-t paper-rule flex justify-between text-sm" style="color: var(--ink-faded);">
    <a href="/" class="link-accent" style="text-decoration: none;">← 首页</a>
    <a href="/archive" class="link-accent" style="text-decoration: none;">所有文章 →</a>
  </div>
</Layout>
