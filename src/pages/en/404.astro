---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="404" description="Page not found" lang="en">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-28 sm:py-36 text-center">
    <p class="font-serif-sc text-[96px] sm:text-[144px] leading-none" style="color: var(--accent);">404</p>
    <div class="my-8 flex justify-center"><span class="rule-accent"></span></div>
    <p class="text-lg" style="color: var(--ink-soft);">Nothing here.</p>
    <a href="/en/" class="inline-flex items-center gap-1.5 mt-10 link-accent"><span>←</span> Back to home</a>
  </div>
</Layout>
