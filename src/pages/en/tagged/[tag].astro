---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("posts-en", ({ data }) => !data.draft);
  const tags = new Map<string, typeof posts>();
  for (const p of posts) {
    for (const t of p.data.tags) {
      if (!tags.has(t)) tags.set(t, []);
      tags.get(t)!.push(p);
    }
  }
  return Array.from(tags.entries()).map(([tag, list]) => ({
    params: { tag },
    props: {
      tag,
      posts: list.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
};

const { tag, posts } = Astro.props;
const fmtYMD = (d: Date) => {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y} / ${m} / ${day}`;
};
---
<Layout title={`Tagged: ${tag}`} description={`Posts tagged ${tag}`} lang="en">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-16 sm:py-20">
    <header class="mb-16">
      <div class="eyebrow mb-4">Tagged</div>
      <h1 class="font-serif-sc text-[44px] sm:text-[56px] tracking-tight mb-4" style="color: var(--ink);">
        #{tag}
      </h1>
      <div class="flex items-center gap-4">
        <span class="rule-accent"></span>
        <span class="text-sm" style="color: var(--ink-soft);">{posts.length} posts</span>
      </div>
    </header>

    <ul class="space-y-4">
      {posts.map((p) => (
        <li class="flex items-baseline gap-5 flex-wrap">
          <time class="text-xs font-mono min-w-[7rem]" style="color: var(--ink-faded);" datetime={p.data.date.toISOString()}>
            {fmtYMD(p.data.date)}
          </time>
          <a href={`/en/post/${p.slug}`} class="text-[15px] hover:text-[color:var(--accent-hover)] transition-colors" style="color: var(--ink);">
            {p.data.title}
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-20 text-sm">
      <a href="/en/tags" class="link-accent inline-flex items-center gap-1.5"><span>←</span> All tags</a>
    </div>
  </div>
</Layout>
