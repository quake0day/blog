---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const counts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tags = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
const maxN = Math.max(1, ...tags.map(([, n]) => n));
---
<Layout title="Tags" description="All tags on PSYcHiC">
  <header class="mb-10 text-center">
    <div class="eyebrow mb-3">标签索引</div>
    <h1 class="text-3xl font-bold tracking-tight" style="color: var(--ink);">Tags</h1>
    <p class="text-sm mt-2" style="color: var(--ink-faded);">
      {tags.length} 个标签 &nbsp;·&nbsp; 覆盖 {posts.length} 篇
    </p>
  </header>

  <div class="flex flex-wrap gap-3 justify-center">
    {tags.map(([t, n]) => {
      const scale = 0.95 + (n / maxN) * 0.8;
      return (
        <a href={`/tagged/${encodeURIComponent(t)}`}
          class="inline-flex items-baseline gap-1 link-accent transition-opacity hover:opacity-80"
          style={`font-size: ${scale}rem; text-decoration: none;`}>
          <span>#{t}</span>
          <span class="text-xs font-mono" style="color: var(--ink-faded);">{n}</span>
        </a>
      );
    })}
  </div>
</Layout>
