---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);

const fmtMD = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "2-digit" });
---
<Layout title="Archive" description={`All ${posts.length} posts`}>
  <header class="mb-10 text-center">
    <div class="eyebrow mb-3">所有日志</div>
    <h1 class="text-3xl font-bold tracking-tight" style="color: var(--ink);">Archive</h1>
    <p class="text-sm mt-2" style="color: var(--ink-faded);">{posts.length} 篇 &nbsp;·&nbsp; since 2004</p>
  </header>

  {years.map((year) => (
    <section class="mb-12">
      <h2 class="text-sm font-bold mb-4 pb-2 border-b paper-rule tracking-[0.18em]" style="color: var(--ink-soft);">
        {year}
      </h2>
      <ul class="space-y-2.5">
        {byYear.get(year)!.map((p) => (
          <li class="flex items-baseline gap-4 flex-wrap">
            <time class="text-xs font-mono min-w-[3.25rem]" style="color: var(--ink-faded);" datetime={p.data.date.toISOString()}>
              {fmtMD(p.data.date)}
            </time>
            <a href={`/post/${p.slug}`} class="text-base hover:text-[var(--ink-accent)] transition-colors" style="color: var(--ink);">
              {p.data.title}
            </a>
            {p.data.tags.length > 0 && (
              <span class="text-xs" style="color: var(--ink-faded);">
                {p.data.tags.slice(0, 2).map((t) => `#${t}`).join(" ")}
              </span>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>
