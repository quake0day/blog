---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404" description="Page not found">
  <div class="text-center py-16">
    <p class="text-6xl font-bold text-gray-900 dark:text-white font-mono">404</p>
    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">这里什么都没有 / Nothing here.</p>
    <a href="/" class="inline-block mt-8 px-5 py-2 rounded border border-stone-300 dark:border-gray-700 hover:bg-stone-100 dark:hover:bg-gray-800 transition-colors">
      ← Back to home
    </a>
  </div>
</Layout>
