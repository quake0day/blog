---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const tags = new Map<string, typeof posts>();
  for (const p of posts) {
    for (const t of p.data.tags) {
      if (!tags.has(t)) tags.set(t, []);
      tags.get(t)!.push(p);
    }
  }
  return Array.from(tags.entries()).map(([tag, list]) => ({
    params: { tag },
    props: {
      tag,
      posts: list.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
};

const { tag, posts } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" });
---
<Layout title={`Tagged: ${tag}`} description={`Posts tagged ${tag}`}>
  <header class="mb-10 text-center">
    <div class="eyebrow mb-3">标签</div>
    <h1 class="text-3xl font-bold tracking-tight" style="color: var(--ink);">#{tag}</h1>
    <p class="text-sm mt-2" style="color: var(--ink-faded);">{posts.length} 篇</p>
  </header>

  <ul class="space-y-3">
    {posts.map((p) => (
      <li class="flex items-baseline gap-4 flex-wrap">
        <time class="text-xs font-mono min-w-[6rem]" style="color: var(--ink-faded);" datetime={p.data.date.toISOString()}>
          {fmt(p.data.date)}
        </time>
        <a href={`/post/${p.slug}`} class="text-base hover:text-[var(--ink-accent)] transition-colors" style="color: var(--ink);">
          {p.data.title}
        </a>
      </li>
    ))}
  </ul>

  <div class="mt-12 text-sm text-center">
    <a href="/tags" class="link-accent" style="text-decoration: none;">← 所有标签</a>
  </div>
</Layout>
