---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---
<section id="comments" class="mt-12">
  <h3 class="text-base font-semibold mb-5 flex items-center gap-2" style="color: var(--ink); letter-spacing: 0.04em;">
    <span>留言</span>
    <span class="text-sm font-normal font-mono" style="color: var(--ink-faded);" id="comments-count"></span>
  </h3>

  <div id="comments-list" class="space-y-4 mb-10" data-slug={slug}>
    <p class="text-sm italic" style="color: var(--ink-faded);">加载中…</p>
  </div>

  <form id="comment-form" class="pt-8" data-slug={slug} style="border-top: 1px solid var(--rule);">
    <h4 class="eyebrow mb-5">发表留言</h4>
    <input name="name" required maxlength="80" placeholder="姓名"
      class="paper-input w-full text-sm rounded px-3.5 py-2.5" />
    <textarea name="body" required rows="5" maxlength="2000" placeholder="在此写下你的留言……"
      class="paper-input mt-3 w-full text-sm rounded px-3.5 py-2.5 resize-y"
      style="font-family: inherit;"></textarea>
    <!-- honeypot -->
    <input name="hp_url" tabindex="-1" autocomplete="off" aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />
    <div class="mt-4 flex items-center justify-end gap-3 flex-wrap">
      <button type="submit" class="paper-btn text-sm px-6 py-2.5 rounded disabled:opacity-50">
        提交
      </button>
    </div>
    <p id="comment-status" class="mt-3 text-sm hidden"></p>
  </form>
</section>

<script is:inline>
  (function () {
    var listEl = document.getElementById("comments-list");
    var countEl = document.getElementById("comments-count");
    var formEl = document.getElementById("comment-form");
    var statusEl = document.getElementById("comment-status");
    if (!listEl || !formEl) return;
    var slug = listEl.getAttribute("data-slug") || "";
    var LOCAL_KEY = "psychic-my-cmts-" + slug;

    function esc(s) {
      return String(s || "").replace(/[&<>"']/g, function (c) {
        return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c];
      });
    }
    function fmtDate(ts) {
      try {
        return new Date(ts).toLocaleString("zh-CN", {
          year: "numeric", month: "short", day: "numeric",
          hour: "2-digit", minute: "2-digit",
        });
      } catch { return ""; }
    }
    function nl2br(s) { return esc(s).replace(/\n/g, "<br>"); }

    // Visitor's own "pending" comments stored here, only visible in their own browser.
    function loadLocal() {
      try { return JSON.parse(localStorage.getItem(LOCAL_KEY) || "[]"); }
      catch { return []; }
    }
    function saveLocal(arr) {
      try { localStorage.setItem(LOCAL_KEY, JSON.stringify(arr)); } catch {}
    }
    function pruneLocal(serverIds) {
      var kept = loadLocal().filter(function (c) { return !serverIds.has(c.id); });
      saveLocal(kept);
      return kept;
    }

    function render(comments) {
      var n = comments.length;
      countEl.textContent = n ? "· " + n : "";
      if (!n) {
        listEl.innerHTML = '<p class="text-sm italic" style="color: var(--ink-faded);">还没有留言,写下第一条吧。</p>';
        return;
      }
      listEl.innerHTML = comments.map(function (c) {
        var nameHtml = c.website
          ? '<a href="' + esc(c.website) + '" target="_blank" rel="nofollow noopener noreferrer" class="link-accent" style="text-decoration:none">' + esc(c.name) + '</a>'
          : esc(c.name);
        return (
          '<article class="comment-card rounded-sm p-4">' +
            '<header class="flex items-baseline justify-between gap-2 mb-2">' +
              '<strong class="text-sm" style="color: var(--ink);">' + nameHtml + '</strong>' +
              '<time class="text-xs font-mono" style="color: var(--ink-faded);">' + fmtDate(c.created_at) + '</time>' +
            '</header>' +
            '<p class="text-sm leading-relaxed" style="color: var(--ink-soft);">' + nl2br(c.body) + '</p>' +
          '</article>'
        );
      }).join("");
    }

    function refresh() {
      fetch("/api/comments?slug=" + encodeURIComponent(slug))
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var server = data.comments || [];
          var serverIds = new Set(server.map(function (c) { return c.id; }));
          // Drop any local entries whose server counterparts have appeared (i.e., approved).
          var local = pruneLocal(serverIds);
          // Server-approved first (by created_at), then local pending, then render.
          var merged = server.concat(local);
          // Sort ascending by created_at to match backend order.
          merged.sort(function (a, b) { return (a.created_at || 0) - (b.created_at || 0); });
          render(merged);
        })
        .catch(function () {
          listEl.innerHTML = '<p class="text-sm" style="color: #c03;">评论加载失败。</p>';
        });
    }
    refresh();

    formEl.addEventListener("submit", function (ev) {
      ev.preventDefault();
      statusEl.className = "mt-3 text-sm";
      statusEl.textContent = "提交中...";
      statusEl.classList.remove("hidden");

      var fd = new FormData(formEl);
      var payload = {
        slug: slug,
        name: fd.get("name") || "",
        body: fd.get("body") || "",
        hp_url: fd.get("hp_url") || "",
      };
      var btn = formEl.querySelector('button[type="submit"]');
      btn.disabled = true;

      fetch("/api/comments", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
        .then(function (res) {
          btn.disabled = false;
          if (res.ok && res.d.ok) {
            // Stash the new comment locally so only this visitor sees it until moderated.
            if (res.d.comment) {
              var local = loadLocal();
              local.push(res.d.comment);
              saveLocal(local);
            }
            statusEl.textContent = "已提交 ✓";
            statusEl.className = "mt-3 text-sm";
            statusEl.style.color = "var(--accent-deep)";
            formEl.reset();
            refresh();
          } else {
            statusEl.textContent = (res.d && res.d.error) || "提交失败,请稍后再试。";
            statusEl.className = "mt-3 text-sm";
            statusEl.style.color = "#c03";
          }
        })
        .catch(function () {
          btn.disabled = false;
          statusEl.textContent = "网络错误,请稍后再试。";
          statusEl.className = "mt-3 text-sm";
          statusEl.style.color = "#c03";
        });
    });
  })();
</script>
