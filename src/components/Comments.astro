---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---
<section id="comments" class="mt-12">
  <h3 class="text-base font-semibold mb-5 flex items-center gap-2" style="color: var(--ink); letter-spacing: 0.05em;">
    <span>留言</span>
    <span class="text-sm font-normal font-mono" style="color: var(--ink-faded);" id="comments-count"></span>
  </h3>

  <div id="comments-list" class="space-y-4 mb-10" data-slug={slug}>
    <p class="text-sm italic" style="color: var(--ink-faded);">加载中…</p>
  </div>

  <form id="comment-form" class="border-t paper-rule pt-8" data-slug={slug}>
    <h4 class="eyebrow mb-4">发表一条留言</h4>
    <div class="grid gap-3 sm:grid-cols-2">
      <input name="name" required maxlength="80" placeholder="姓名(必填)"
        class="text-sm rounded-sm px-3 py-2.5 focus:outline-none focus:ring-1"
        style="background: var(--paper-bg); border: 1px solid var(--paper-rule); color: var(--ink);" />
      <input name="email" type="email" maxlength="120" placeholder="邮箱(选填,不公开)"
        class="text-sm rounded-sm px-3 py-2.5 focus:outline-none focus:ring-1"
        style="background: var(--paper-bg); border: 1px solid var(--paper-rule); color: var(--ink);" />
    </div>
    <input name="website" maxlength="200" placeholder="网址(选填,以 http:// 开头)"
      class="mt-3 w-full text-sm rounded-sm px-3 py-2.5 focus:outline-none focus:ring-1"
      style="background: var(--paper-bg); border: 1px solid var(--paper-rule); color: var(--ink);" />
    <textarea name="body" required rows="5" maxlength="2000" placeholder="在此写下你的留言……"
      class="mt-3 w-full text-sm rounded-sm px-3 py-2.5 focus:outline-none focus:ring-1 resize-y"
      style="background: var(--paper-bg); border: 1px solid var(--paper-rule); color: var(--ink); font-family: inherit;"></textarea>
    <!-- honeypot -->
    <input name="hp_url" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />
    <div class="mt-4 flex items-center justify-between gap-3 flex-wrap">
      <p class="text-xs" style="color: var(--ink-faded);">留言需经管理员审核后才会显示。</p>
      <button type="submit"
        class="text-sm px-5 py-2 rounded-sm transition-all disabled:opacity-50"
        style="background: var(--ink); color: var(--paper-bg); letter-spacing: 0.1em;">
        提交
      </button>
    </div>
    <p id="comment-status" class="mt-3 text-sm hidden"></p>
  </form>
</section>

<script is:inline>
  (function () {
    var listEl = document.getElementById("comments-list");
    var countEl = document.getElementById("comments-count");
    var formEl = document.getElementById("comment-form");
    var statusEl = document.getElementById("comment-status");
    if (!listEl || !formEl) return;
    var slug = listEl.getAttribute("data-slug") || "";

    function esc(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c];
      });
    }
    function fmtDate(ts) {
      try {
        return new Date(ts).toLocaleString("zh-CN", {
          year: "numeric", month: "short", day: "numeric",
          hour: "2-digit", minute: "2-digit",
        });
      } catch { return ""; }
    }
    function nl2br(s) { return esc(s).replace(/\n/g, "<br>"); }

    function render(comments) {
      countEl.textContent = comments.length ? "· " + comments.length : "";
      if (!comments.length) {
        listEl.innerHTML = '<p class="text-sm italic" style="color: var(--ink-faded);">还没有留言,写下第一条吧。</p>';
        return;
      }
      listEl.innerHTML = comments.map(function (c) {
        var nameHtml = c.website
          ? '<a href="' + esc(c.website) + '" target="_blank" rel="nofollow noopener noreferrer" class="link-accent" style="text-decoration:none">' + esc(c.name) + '</a>'
          : esc(c.name);
        return (
          '<article class="comment-card rounded-sm p-4">' +
            '<header class="flex items-baseline justify-between gap-2 mb-2">' +
              '<strong class="text-sm" style="color: var(--ink);">' + nameHtml + '</strong>' +
              '<time class="text-xs font-mono" style="color: var(--ink-faded);">' + fmtDate(c.created_at) + '</time>' +
            '</header>' +
            '<p class="text-sm leading-relaxed" style="color: var(--ink-soft);">' + nl2br(c.body) + '</p>' +
          '</article>'
        );
      }).join("");
    }

    function load() {
      fetch("/api/comments?slug=" + encodeURIComponent(slug))
        .then(function (r) { return r.json(); })
        .then(function (data) { render(data.comments || []); })
        .catch(function () {
          listEl.innerHTML = '<p class="text-sm text-red-600">评论加载失败。</p>';
        });
    }
    load();

    formEl.addEventListener("submit", function (ev) {
      ev.preventDefault();
      statusEl.className = "mt-3 text-sm";
      statusEl.textContent = "提交中...";
      statusEl.classList.remove("hidden");

      var fd = new FormData(formEl);
      var payload = {
        slug: slug,
        name: fd.get("name") || "",
        email: fd.get("email") || "",
        website: fd.get("website") || "",
        body: fd.get("body") || "",
        hp_url: fd.get("hp_url") || "",
      };
      var btn = formEl.querySelector('button[type="submit"]');
      btn.disabled = true;

      fetch("/api/comments", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
        .then(function (res) {
          btn.disabled = false;
          if (res.ok && res.d.ok) {
            statusEl.textContent = res.d.message || "已提交,等待审核。";
            statusEl.className = "mt-3 text-sm text-green-700 dark:text-green-400";
            formEl.reset();
          } else {
            statusEl.textContent = (res.d && res.d.error) || "提交失败,请稍后再试。";
            statusEl.className = "mt-3 text-sm text-red-600 dark:text-red-400";
          }
        })
        .catch(function () {
          btn.disabled = false;
          statusEl.textContent = "网络错误,请稍后再试。";
          statusEl.className = "mt-3 text-sm text-red-600 dark:text-red-400";
        });
    });
  })();
</script>
