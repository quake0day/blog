---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---
<section id="comments" class="mt-12">
  <header class="mb-6 flex items-baseline gap-3">
    <span class="eyebrow">留 &middot; 言</span>
    <span class="home-divider flex-1"></span>
    <span id="comments-count" class="text-xs font-mono" style="color: var(--ink-faded);"></span>
  </header>

  <div id="chat-panel" class="chat-panel" data-slug={slug}>
    <div id="chat-scroll" class="chat-scroll">
      <div id="chat-empty" class="chat-empty hidden">
        <div class="chat-empty-bubble">
          <span>🌱</span>
          <p>还没有人留言,在下面说两句吧。</p>
        </div>
      </div>
      <div id="chat-loading" class="chat-loading">
        <span></span><span></span><span></span>
      </div>
      <ul id="chat-list" class="chat-list" aria-live="polite"></ul>
    </div>

    <form id="chat-form" class="chat-composer" autocomplete="off">
      <div class="chat-composer-name">
        <input
          id="chat-name"
          name="name"
          required
          maxlength="80"
          placeholder="你的称呼"
          class="chat-name-input"
          aria-label="姓名"
        />
      </div>
      <div class="chat-composer-main">
        <textarea
          id="chat-body"
          name="body"
          required
          rows="1"
          maxlength="2000"
          placeholder="在这里写下想说的话…… (Enter 发送,Shift+Enter 换行)"
          class="chat-body-input"
          aria-label="留言内容"
        ></textarea>
        <button id="chat-send" type="submit" class="chat-send" aria-label="发送">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 2 11 13"></path>
            <path d="M22 2l-7 20-4-9-9-4 20-7z"></path>
          </svg>
        </button>
      </div>
      <!-- honeypot -->
      <input name="hp_url" tabindex="-1" autocomplete="off" aria-hidden="true"
        style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />
      <p id="chat-status" class="chat-status" role="status"></p>
    </form>
  </div>
</section>

<style>
  .chat-panel {
    background: var(--bg-panel);
    border: 1px solid var(--rule);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(20, 40, 70, 0.03),
                0 12px 30px -12px rgba(20, 40, 70, 0.08);
  }
  :global(.dark) .chat-panel {
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25),
                0 12px 30px -12px rgba(0, 0, 0, 0.4);
  }

  .chat-scroll {
    padding: 22px 18px 10px;
    max-height: 520px;
    overflow-y: auto;
    background:
      radial-gradient(circle at 12% 0%, var(--bg-sky-soft) 0%, transparent 55%),
      radial-gradient(circle at 88% 100%, var(--bg-sky-soft) 0%, transparent 55%),
      var(--bg-panel);
  }
  :global(.dark) .chat-scroll {
    background:
      radial-gradient(circle at 12% 0%, var(--bg-sky-soft) 0%, transparent 60%),
      radial-gradient(circle at 88% 100%, var(--bg-sky-soft) 0%, transparent 60%),
      var(--bg-panel);
  }
  .chat-scroll::-webkit-scrollbar { width: 6px; }
  .chat-scroll::-webkit-scrollbar-thumb {
    background: var(--rule);
    border-radius: 999px;
  }

  .chat-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chat-loading {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 20px 0;
  }
  .chat-loading span {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--ink-faded);
    opacity: 0.5;
    animation: chatDots 1.1s ease-in-out infinite;
  }
  .chat-loading span:nth-child(2) { animation-delay: 0.15s; }
  .chat-loading span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes chatDots {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.35; }
    40% { transform: translateY(-4px); opacity: 1; }
  }

  .chat-empty {
    display: flex;
    justify-content: center;
    padding: 22px 0 12px;
  }
  .chat-empty-bubble {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--bg-sky-soft);
    color: var(--ink-soft);
    font-size: 13px;
  }
  .chat-empty-bubble p { margin: 0; }

  /* ==== message row ==== */
  .chat-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
    animation: bubbleIn 0.35s cubic-bezier(0.2, 0.85, 0.2, 1) both;
  }
  .chat-row.is-self { flex-direction: row-reverse; }

  @keyframes bubbleIn {
    from { opacity: 0; transform: translateY(8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat-row { animation: none; }
  }

  .chat-avatar {
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Montserrat", "PingFang SC", sans-serif;
    box-shadow: 0 1px 3px rgba(20, 40, 70, 0.15);
    user-select: none;
  }

  .chat-stack {
    display: flex;
    flex-direction: column;
    max-width: min(78%, 520px);
    min-width: 0;
  }
  .chat-row.is-self .chat-stack { align-items: flex-end; }

  .chat-meta {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin: 0 6px 4px;
    font-size: 11.5px;
    color: var(--ink-faded);
  }
  .chat-row.is-self .chat-meta { flex-direction: row-reverse; }
  .chat-meta .chat-name {
    font-weight: 600;
    color: var(--ink-soft);
    letter-spacing: 0.01em;
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .chat-meta .chat-time {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .chat-meta .chat-pending {
    font-size: 10.5px;
    padding: 1px 7px;
    border-radius: 999px;
    background: var(--bg-sky-soft);
    color: var(--accent-deep);
    letter-spacing: 0.04em;
  }
  :global(.dark) .chat-meta .chat-pending { color: var(--accent); }

  .chat-bubble {
    position: relative;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 14.5px;
    line-height: 1.7;
    word-wrap: break-word;
    overflow-wrap: anywhere;
    white-space: pre-wrap;
    letter-spacing: 0.005em;
  }

  /* others -- left, paper tone */
  .chat-row.is-other .chat-bubble {
    background: var(--bg-panel);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-bottom-left-radius: 4px;
  }
  :global(.dark) .chat-row.is-other .chat-bubble {
    background: var(--bg-sky-soft);
    border-color: var(--rule);
  }

  /* self -- right, accent */
  .chat-row.is-self .chat-bubble {
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-hover) 100%);
    color: #ffffff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 1px 2px rgba(58, 154, 217, 0.28),
                0 6px 18px -6px rgba(58, 154, 217, 0.35);
  }
  :global(.dark) .chat-row.is-self .chat-bubble {
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-deep) 100%);
    color: #081019;
    box-shadow: 0 1px 2px rgba(98, 184, 230, 0.25),
                0 6px 18px -6px rgba(98, 184, 230, 0.35);
  }

  .chat-bubble a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 0.5px;
    text-underline-offset: 2px;
    opacity: 0.9;
  }

  /* composer */
  .chat-composer {
    position: relative;
    padding: 12px 14px 14px;
    border-top: 1px solid var(--rule);
    background: var(--bg-panel);
  }
  :global(.dark) .chat-composer { background: var(--bg-panel); }

  .chat-composer-name {
    margin-bottom: 8px;
  }
  .chat-name-input {
    width: 100%;
    max-width: 220px;
    background: transparent;
    border: none;
    border-bottom: 1px dashed var(--rule);
    padding: 4px 2px;
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 0.01em;
    outline: none;
    transition: border-color 0.15s;
  }
  .chat-name-input::placeholder { color: var(--ink-faded); }
  .chat-name-input:focus { border-bottom-color: var(--accent); }

  .chat-composer-main {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    background: var(--bg-sky-soft);
    border: 1px solid var(--rule);
    border-radius: 22px;
    padding: 6px 6px 6px 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .chat-composer-main:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-pale);
  }

  .chat-body-input {
    flex: 1 1 auto;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    color: var(--ink);
    font-family: inherit;
    font-size: 14.5px;
    line-height: 1.55;
    padding: 6px 0;
    max-height: 180px;
    overflow-y: auto;
  }
  .chat-body-input::placeholder { color: var(--ink-faded); }

  .chat-send {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s, opacity 0.15s;
  }
  .chat-send:hover:not(:disabled) { background: var(--accent-hover); transform: translateY(-1px); }
  .chat-send:active:not(:disabled) { transform: translateY(0) scale(0.95); }
  .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
  .chat-send svg { transform: translateX(1px); }

  .chat-status {
    margin: 8px 4px 0;
    min-height: 1.2em;
    font-size: 12px;
    color: var(--ink-faded);
    transition: color 0.15s;
  }
  .chat-status.is-ok { color: var(--accent-deep); }
  :global(.dark) .chat-status.is-ok { color: var(--accent); }
  .chat-status.is-err { color: #c03; }
  :global(.dark) .chat-status.is-err { color: #f07a8a; }

  .hidden { display: none !important; }

  @media (max-width: 480px) {
    .chat-scroll { padding: 16px 12px 8px; }
    .chat-stack { max-width: 85%; }
    .chat-avatar { width: 30px; height: 30px; font-size: 12px; }
    .chat-bubble { font-size: 14px; padding: 9px 12px; }
  }
</style>

<script is:inline>
  (function () {
    var panel = document.getElementById("chat-panel");
    if (!panel) return;
    var scrollEl = document.getElementById("chat-scroll");
    var listEl = document.getElementById("chat-list");
    var emptyEl = document.getElementById("chat-empty");
    var loadingEl = document.getElementById("chat-loading");
    var countEl = document.getElementById("comments-count");
    var formEl = document.getElementById("chat-form");
    var nameEl = document.getElementById("chat-name");
    var bodyEl = document.getElementById("chat-body");
    var sendBtn = document.getElementById("chat-send");
    var statusEl = document.getElementById("chat-status");

    var slug = panel.getAttribute("data-slug") || "";
    var LOCAL_KEY = "psychic-my-cmts-" + slug;
    var NAME_KEY  = "psychic-my-name";
    var MINE_IDS_KEY = "psychic-my-ids-" + slug;

    // Restore saved name
    try {
      var savedName = localStorage.getItem(NAME_KEY);
      if (savedName) nameEl.value = savedName;
    } catch {}

    function esc(s) {
      return String(s || "").replace(/[&<>"']/g, function (c) {
        return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c];
      });
    }
    function fmtDate(ts) {
      if (!ts) return "";
      try {
        var d = new Date(ts);
        var now = new Date();
        var diff = (now.getTime() - d.getTime()) / 1000;
        if (diff < 60) return "刚刚";
        if (diff < 3600) return Math.floor(diff / 60) + " 分钟前";
        if (diff < 86400 && d.getDate() === now.getDate())
          return d.toLocaleTimeString("zh-CN", { hour: "2-digit", minute: "2-digit" });
        return d.toLocaleString("zh-CN", {
          month: "short", day: "numeric", hour: "2-digit", minute: "2-digit"
        });
      } catch { return ""; }
    }
    function nl2br(s) { return esc(s); }  // CSS white-space:pre-wrap already handles newlines

    // Stable hue from name string
    function avatarFor(name) {
      var s = String(name || "匿名");
      var h = 0;
      for (var i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) & 0x7fffffff;
      var hues = [210, 195, 185, 230, 170, 248, 205, 220, 190];
      var hue = hues[h % hues.length];
      var c1 = "hsl(" + hue + ", 55%, 58%)";
      var c2 = "hsl(" + ((hue + 24) % 360) + ", 55%, 45%)";
      // First CJK char or first 1-2 latin chars
      var initial = "";
      var m = s.match(/[一-鿿㐀-䶿぀-ヿ가-힯]/);
      if (m) initial = m[0];
      else initial = s.replace(/\s+/g, "").slice(0, 2).toUpperCase();
      if (!initial) initial = "·";
      return {
        initial: initial,
        style: "background:linear-gradient(135deg," + c1 + "," + c2 + ");"
      };
    }

    function loadLocal() {
      try { return JSON.parse(localStorage.getItem(LOCAL_KEY) || "[]"); }
      catch { return []; }
    }
    function saveLocal(arr) {
      try { localStorage.setItem(LOCAL_KEY, JSON.stringify(arr)); } catch {}
    }
    function loadMineIds() {
      try { return new Set(JSON.parse(localStorage.getItem(MINE_IDS_KEY) || "[]")); }
      catch { return new Set(); }
    }
    function saveMineIds(set) {
      try { localStorage.setItem(MINE_IDS_KEY, JSON.stringify(Array.from(set))); } catch {}
    }

    function rowHTML(c, opts) {
      var isSelf = !!(opts && opts.self);
      var isPending = !!(opts && opts.pending);
      var av = avatarFor(c.name);
      var nameHtml = c.website
        ? '<a href="' + esc(c.website) + '" target="_blank" rel="nofollow noopener noreferrer" style="color:inherit;text-decoration:none;">' + esc(c.name) + '</a>'
        : esc(c.name);
      return (
        '<li class="chat-row ' + (isSelf ? 'is-self' : 'is-other') + '">' +
          '<div class="chat-avatar" style="' + av.style + '" aria-hidden="true">' + esc(av.initial) + '</div>' +
          '<div class="chat-stack">' +
            '<div class="chat-meta">' +
              '<span class="chat-name">' + nameHtml + '</span>' +
              '<span class="chat-time">' + fmtDate(c.created_at) + '</span>' +
              (isPending ? '<span class="chat-pending">审核中</span>' : '') +
            '</div>' +
            '<div class="chat-bubble">' + nl2br(c.body) + '</div>' +
          '</div>' +
        '</li>'
      );
    }

    function render(rows) {
      if (!rows.length) {
        listEl.innerHTML = "";
        emptyEl.classList.remove("hidden");
        countEl.textContent = "";
        return;
      }
      emptyEl.classList.add("hidden");
      countEl.textContent = rows.length + " 条";
      listEl.innerHTML = rows.map(function (r) { return rowHTML(r.c, r.opts); }).join("");
    }

    function autoScrollIfAtBottom(before) {
      // scroll to bottom on new messages if user was near the bottom, or always on first load
      var el = scrollEl;
      el.scrollTop = el.scrollHeight;
    }

    function refresh(keepScroll) {
      return fetch("/api/comments?slug=" + encodeURIComponent(slug))
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loadingEl.classList.add("hidden");
          var server = data.comments || [];
          var serverIds = new Set(server.map(function (c) { return c.id; }));
          var mineIds = loadMineIds();

          // Drop local-pending rows whose server-approved counterparts are now present.
          var local = loadLocal().filter(function (c) { return !serverIds.has(c.id); });
          saveLocal(local);

          var rows = [];
          server.forEach(function (c) {
            rows.push({ c: c, opts: { self: mineIds.has(c.id), pending: false } });
          });
          local.forEach(function (c) {
            rows.push({ c: c, opts: { self: true, pending: true } });
          });
          rows.sort(function (a, b) { return (a.c.created_at || 0) - (b.c.created_at || 0); });

          render(rows);
          if (!keepScroll) autoScrollIfAtBottom();
        })
        .catch(function () {
          loadingEl.classList.add("hidden");
          listEl.innerHTML = '<li class="chat-row is-other"><div class="chat-stack"><div class="chat-bubble" style="color:#c03;background:transparent;border:none;">留言加载失败,请刷新重试。</div></div></li>';
        });
    }
    refresh();

    // Auto-grow textarea
    function autogrow() {
      bodyEl.style.height = "auto";
      bodyEl.style.height = Math.min(bodyEl.scrollHeight, 180) + "px";
    }
    bodyEl.addEventListener("input", autogrow);

    // Enter to send (Shift+Enter = newline)
    bodyEl.addEventListener("keydown", function (ev) {
      if (ev.key === "Enter" && !ev.shiftKey && !ev.isComposing) {
        ev.preventDefault();
        if (!sendBtn.disabled) formEl.requestSubmit();
      }
    });

    function setStatus(kind, text) {
      statusEl.classList.remove("is-ok", "is-err");
      if (kind === "ok") statusEl.classList.add("is-ok");
      else if (kind === "err") statusEl.classList.add("is-err");
      statusEl.textContent = text || "";
    }

    formEl.addEventListener("submit", function (ev) {
      ev.preventDefault();
      var name = (nameEl.value || "").trim();
      var text = (bodyEl.value || "").trim();
      if (!name) { setStatus("err", "请填写称呼"); nameEl.focus(); return; }
      if (text.length < 2) { setStatus("err", "留言太短啦"); bodyEl.focus(); return; }

      try { localStorage.setItem(NAME_KEY, name); } catch {}

      setStatus("", "发送中…");
      sendBtn.disabled = true;

      var payload = { slug: slug, name: name, body: text, hp_url: formEl.hp_url.value || "" };

      // Optimistic bubble: temporary row, replaced by server result
      var tempId = "__tmp_" + Date.now() + "_" + Math.random().toString(36).slice(2, 7);
      emptyEl.classList.add("hidden");
      var tmpItem = document.createElement("li");
      tmpItem.className = "chat-row is-self";
      tmpItem.setAttribute("data-tmp-id", tempId);
      var av = avatarFor(name);
      tmpItem.innerHTML =
        '<div class="chat-avatar" style="' + av.style + '" aria-hidden="true">' + esc(av.initial) + '</div>' +
        '<div class="chat-stack">' +
          '<div class="chat-meta">' +
            '<span class="chat-name">' + esc(name) + '</span>' +
            '<span class="chat-time">刚刚</span>' +
            '<span class="chat-pending">发送中…</span>' +
          '</div>' +
          '<div class="chat-bubble" style="opacity:0.85;">' + esc(text) + '</div>' +
        '</div>';
      listEl.appendChild(tmpItem);
      scrollEl.scrollTop = scrollEl.scrollHeight;
      bodyEl.value = "";
      autogrow();

      fetch("/api/comments", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
        .then(function (res) {
          sendBtn.disabled = false;
          var tmp = listEl.querySelector('[data-tmp-id="' + tempId + '"]');
          if (res.ok && res.d.ok) {
            if (res.d.comment) {
              var local = loadLocal();
              local.push(res.d.comment);
              saveLocal(local);
              var mineIds = loadMineIds();
              mineIds.add(res.d.comment.id);
              saveMineIds(mineIds);
            }
            setStatus("ok", "已发送 ✓ 留言审核通过后就会公开显示");
            if (tmp) tmp.remove();
            refresh(false);
          } else {
            if (tmp) tmp.remove();
            // Restore the text so the user can edit and retry
            bodyEl.value = text;
            autogrow();
            setStatus("err", (res.d && res.d.error) || "发送失败,请稍后再试");
          }
        })
        .catch(function () {
          sendBtn.disabled = false;
          var tmp = listEl.querySelector('[data-tmp-id="' + tempId + '"]');
          if (tmp) tmp.remove();
          bodyEl.value = text;
          autogrow();
          setStatus("err", "网络错误,请稍后再试");
        });
    });
  })();
</script>
